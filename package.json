{
  "name": "aria2-ng-extension",
  "version": "1.0.0",
  "description": "Browser extension that automatically intercepts downloads to aria2 with AriaNg UI",
  "type": "module",
  "scripts": {
    "build": "bun run build:firefox",
    "build:firefox": "bun scripts/build.js firefox",
    "dev:firefox": "bun scripts/build.js firefox --watch",
    "download:ariang": "bun scripts/download-ariang.js",
    "lint": "biome check src/ public/",
    "lint:fix": "biome check --write src/ public/"
  },
  "keywords": [
    "aria2",
    "ariang",
    "browser-extension",
    "download-manager",
    "web-extension"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "biome": "^0.3.3",
    "chokidar": "^4.0.1"
  }
}
