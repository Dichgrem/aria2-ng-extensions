{
	"name": "aria2-helper",
	"version": "2.0.0",
	"author": "",
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/adm-zip": "^0.5.8",
		"adm-zip": "^0.5.17",
		"typescript": "^5.9.3",
		"wxt": "^0.20.20"
	},
	"description": "Browser extension that automatically intercepts downloads to aria2",
	"keywords": [
		"aria2",
		"browser-extension",
		"download-manager",
		"web-extension"
	],
	"license": "MIT",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
